  "keyFeatures": [
    "Autonomous monitoring and repair of Linux services (Nginx, PostgreSQL, Docker)",
    "RAG-powered diagnosis using Pinecone, LlamaIndex, and Cohere Rerank",
    "LangGraph-based agent workflow with human-in-the-loop approval",
    "Real-time dashboard with live terminal and WebSocket updates",
    "Secure SSH-based command execution with safety controls",
    "Interactive chat interface for querying technical documentation"
  ],
  "publicApiSurface": [
    "POST /agent/run - Start the agent monitoring cycle",
    "POST /agent/stop - Stop the running agent",
    "POST /agent/approve - Approve or reject agent actions",
    "GET /agent/state - Get current agent state",
    "GET /status - Get service status",
    "POST /chat - Query the knowledge base",
    "WebSocket /ws/logs - Real-time log streaming",
    "VectorKnowledgeBase.query() - Query RAG system",
    "SSHClient.execute_command() - Execute remote commands",
    "AgentGraph workflow nodes: monitor, diagnose, plan, approve, execute, verify"
  ]
}
